<%- include('partials/header', { title: 'Home' , user: user }) %>

  <!-- Hero Section -->
  <div class="hero-section text-center d-flex align-items-center justify-content-center vh-100 text-white" style="
    background-image: url('https://cdn.pixabay.com/photo/2019/06/01/02/14/lake-4243352_1280.jpg');
    background-size: cover;
    background-position: center;
    position: relative;
  ">
    <div style="
      background-color: rgba(0, 0, 0, 0.6);
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    "></div>
    <div class="container" style="position: relative">
      <h1 class="display-3 fw-bolder mb-4">Welcome to The Blog Application</h1>
      <p class="lead fw-medium mb-4">A place to share your thoughts and ideas</p>

      <% if (user) { %>

        <div class="mt-4">


          <div
            class="d-inline-flex align-items-center gap-2 bg-secondary bg-opacity-25 rounded-pill px-4 py-3 mb-4 text-white">


            <span class="fw-bolder fs-4 ">
              Welcome back, <%= user.username %>

            </span>




          </div>

          <br>

          <a href="/user/profile" class="btn btn-primary btn-lg rounded-pill px-5 shadow">

            <i class="fas fa-user me-2"></i>
            View Profile

          </a>

        </div>

        <% } else { %>

          <div class="mt-4">

            <p class="lead fw-medium text-white mb-4">
              Join the community and start sharing your ideas.
            </p>

            <div class="d-flex justify-content-center gap-3 flex-wrap">

              <a href="/auth/login" class="btn btn-primary btn-lg rounded-pill px-5">

                <i class="fas fa-sign-in-alt me-2"></i>
                Login

              </a>

              <a href="/auth/register" class="btn btn-warning btn-lg rounded-pill px-5">

                <i class="fas fa-user-plus me-2"></i>
                Register

              </a>

            </div>

          </div>

          <% } %>


    </div>
  </div>

  <!-- Features Section -->
  <div class="container-fluid mt-5">
    <h1 class="text-center font-weight-bold mb-4">Application Features</h1>
    <div class="row">
      <div class="col-md-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-lock fa-3x mb-3" style="color: #ff6f61"></i>
            <h3 class="card-title">Authentication</h3>
            <p class="card-text">
              Securely access your account with our robust authentication system.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-user-shield fa-3x mb-3" style="color: #6a4c93"></i>
            <h3 class="card-title">Authorization</h3>
            <p class="card-text">
              Control who has access to different parts of the site.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-sign-in-alt fa-3x mb-3" style="color: #ffa600"></i>
            <h3 class="card-title">Login</h3>
            <p class="card-text">
              Quick and easy login process for returning users.
            </p>
          </div>
        </div>
      </div>
    </div>
    <div class="row mt-4">
      <div class="col-md-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-sign-out-alt fa-3x mb-3" style="color: #ff6f61"></i>
            <h3 class="card-title">Logout</h3>
            <p class="card-text">
              Securely log out of your account to protect your data.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-comments fa-3x mb-3" style="color: #6a4c93"></i>
            <h3 class="card-title">Comments</h3>
            <p class="card-text">
              Engage with the community by leaving comments on posts.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-upload fa-3x mb-3" style="color: #ffa600"></i>
            <h3 class="card-title">Multiple File Uploads</h3>
            <p class="card-text">
              Easily upload multiple files with our intuitive interface.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
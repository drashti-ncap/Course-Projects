<%- include('partials/header', { title, user: user }) %>

<div class="container py-5">

  <!-- Header -->
  <div class="text-center mb-5">
    <h1 class="fw-bold">
      All Posts
    </h1>
    <p class="text-muted">Discover the latest posts from the community</p>
  </div>

  <!-- Posts Grid -->
  <div class="row y g-4">

    <% if (posts.length > 0) { %>
      <% posts.forEach(post => { %>

        <div class="col-lg-4 col-md-6">

          <div class="card h-100 border border-secondary shadow-sm post-card">

            <!-- Image -->
            <% if (post.images && post.images.length > 0) { %>
              <div class="ratio ratio-4x3 overflow-hidden">
                <img
                  src="<%= post.images[0].url %>"
                  class="w-100 h-100 object-fit-cover"
                  alt="Post Image"
                >
              </div>
            <% } else { %>
              <div class="ratio ratio-4x3 bg-light d-flex align-items-center justify-content-center text-muted">
                No Image
              </div>
            <% } %>

            <!-- Body -->
            <div class="card-body d-flex flex-column">

              <h5 class="card-title fw-semibold mb-2">
                <%= post.title %>
              </h5>

              <div class="text-muted small mb-3">
                <i class="fas fa-user me-1"></i>
                <%= post.author.username %>

                <span class="mx-2">•</span>

                <i class="fas fa-calendar-alt me-1"></i>
                <%= post.createdAt.toDateString() %>
              </div>

              <div class="mt-auto">
                <a href="/posts/<%= post._id %>" class="btn btn-primary w-100">
                  Read More
                </a>
              </div>

            </div>
          </div>

        </div>

      <% }) %>

    <% } else { %>
      <div class="col-12 text-center py-5">
        <div class="text-muted">
          <i class="fas fa-folder-open fa-2x mb-3"></i>
          <p class="mb-0">No posts available</p>
        </div>
      </div>
    <% } %>

  </div>
</div>

<!-- Small UI polish (add in your CSS file) -->
<style>
  .post-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border-radius: 12px;
  }

 
  .card-title {
    line-height: 1.3;
  }
</style>

<%- include('partials/footer') %>